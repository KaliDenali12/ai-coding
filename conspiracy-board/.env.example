# Conspiracy Board — Environment Variables
# Copy this file to .env and fill in the values.

# Required: Anthropic API key for Claude API calls
# Get yours at https://console.anthropic.com/
# Used by: netlify/functions/generate.ts (server-side only, never exposed to client)
ANTHROPIC_API_KEY=

# Optional: Timeout for Anthropic SDK API calls in milliseconds
# Default: 25000 (25 seconds)
# Must be less than Netlify function timeout (26s in netlify.toml)
# ANTHROPIC_TIMEOUT_MS=25000
